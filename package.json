{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:analyze": "ANALYZE_DEBUG=true npm run build",
        "tsc": "tsc -b",
        "lint": "npm run prettier && npm run lint:eslint && npm run lint:stylelint && npm run tsc",
        "prettier:fix": "prettier --write .",
        "prettier": "prettier --check .",
        "lint:eslint": "eslint src --ext .js,.jsx,.ts,.tsx",
        "lint:stylelint": "stylelint '**/*.css'",
        "lint:eslint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
        "lint:stylelint:fix": "stylelint '**/*.css' --fix",
        "lint:fix": "npm run lint:eslint:fix && npm run lint:stylelint:fix",
        "preview": "vite preview",
        "build-tokens": "sh ./styleDictionary/build-tokens.sh",
        "style-dictionary-build-colors": "node ./styleDictionary/build-colors.js",
        "style-dictionary-build-sizes": "node ./styleDictionary/build-sizes.js",
        "style-dictionary-build-layouts": "node ./styleDictionary/build-layouts.js",
        "style-dictionary-build-typography": "node ./styleDictionary/build-typography.js"
    },
    "dependencies": {
        "@chakra-ui/react": "^3.27.1",
        "@emotion/react": "^11.14.0",
        "@reduxjs/toolkit": "^2.9.1",
        "clsx": "^2.1.1",
        "i18next": "^26.0.8",
        "next-themes": "^0.4.6",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-i18next": "^17.0.6",
        "react-icons": "^5.5.0",
        "react-markdown": "^10.1.0",
        "react-redux": "^9.2.0",
        "react-router": "^7.9.4",
        "redux": "^5.0.1",
        "rehype-raw": "^7.0.0",
        "remark-gfm": "^4.0.1",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.38.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@vitejs/plugin-react": "^5.0.4",
        "eslint": "^9.38.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react-hooks": "^7.0.0",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.4.0",
        "postcss-lit": "^1.3.1",
        "prettier": "^3.8.3",
        "rimraf": "^6.0.1",
        "style-dictionary": "^5.1.1",
        "stylelint": "^16.25.0",
        "stylelint-config-alphabetical-order": "^1.0.0",
        "stylelint-config-standard": "^39.0.1",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.1",
        "vite": "^7.1.10",
        "vite-bundle-analyzer": "^1.2.3",
        "vite-tsconfig-paths": "^5.1.4"
    }
}

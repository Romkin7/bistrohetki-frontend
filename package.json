{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx && stylelint '**/*.css'",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix && stylelint '**/*.css' --fix",
    "preview": "vite preview",
    "build-tokens": "sh ./styleDictionary/build-tokens.sh",
    "style-dictionary-build-colors": "node ./styleDictionary/build-colors.js",
    "style-dictionary-build-sizes": "node ./styleDictionary/build-sizes.js",
    "style-dictionary-build-layouts": "node ./styleDictionary/build-layouts.js",
    "style-dictionary-build-typography": "node ./styleDictionary/build-typography.js"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.20.0",
    "@emotion/react": "^11.14.0",
    "@reduxjs/toolkit": "^2.8.2",
    "clsx": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.0.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.6.2",
    "redux": "^5.0.1",
    "rehype-raw": "^7.0.0",
    "zod": "^3.25.62"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss-lit": "^1.2.0",
    "rimraf": "^6.0.1",
    "style-dictionary": "^5.0.4",
    "stylelint": "^16.20.0",
    "stylelint-config-alphabetical-order": "^1.0.0",
    "stylelint-config-standard": "^38.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
